# Base URL of the deployed backend API, including the /api/v1 prefix.
# Leave unset for local dev — Vite's proxy (vite.config.js) handles it.
VITE_API_BASE_URL=https://your-backend.up.railway.app/api/v1

# Base URL of the deployed backend for Socket.IO (no path).
# Leave unset for local dev — Vite's proxy handles it.
VITE_SOCKET_URL=https://your-backend.up.railway.app
